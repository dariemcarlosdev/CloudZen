@page "/"
@inject IJSRuntime JS

<PageTitle>CloudZen — Smart Technology Solutions for Growing Businesses</PageTitle>
<HeadContent>
    <meta name="description" content="CloudZen empowers small and medium businesses with smart, scalable technology solutions. We modernize systems, automate workflows, and deliver practical AI — so you can focus on growing." />
    <link rel="canonical" href="https://www.cloud-zen.net/" />
</HeadContent>

@inject NavigationManager NavigationManager

<div class="min-h-screen flex flex-col bg-gray-50">
    <main class="flex-1 flex flex-col items-center w-full">
        <div class="w-full max-w-8xl">
            <HeroWarmTealWash />
            <ToolsOverview />

            <!-- Automation Progress Demo -->
            <section class="py-16 bg-gradient-to-b from-gray-50 to-white">
                <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center mb-8">
                        <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-3">See Automation in Action</h2>
                        <p class="text-gray-500 max-w-xl mx-auto">Watch how we transform legacy systems into streamlined, automated workflows.</p>
                    </div>
                    <AutomationProgressCard />
                </div>
            </section>

            <CaseStudies />
            <FeaturesShowcase />
            <ContactForm />
        </div>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var uri = new Uri(NavigationManager.Uri);
            var fragment = uri.Fragment;

            if (!string.IsNullOrEmpty(fragment))
            {
                // Strip the '#' and scroll to the element (e.g. #cases)
                var elementId = fragment.TrimStart('#');
                await Task.Delay(100); // Allow DOM to render
                await JS.InvokeVoidAsync("scrollToElementById", elementId);
            }
            else
            {
                await JS.InvokeVoidAsync("scrollToHero");
            }
        }
    }
}
