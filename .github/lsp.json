{
  "lspServers": {
    "csharp": {
      "command": "dotnet",
      "args": [
        "tool",
        "run",
        "csharp-ls",
        "--solution",
        "MyApp.sln"
      ],
      "initializationOptions": {
        "AutomaticWorkspaceInit": true
      },
      "fileExtensions": {
        ".cs": "csharp",
        ".csproj": "xml",
        ".razor": "razor",
        ".razor.cs": "csharp"
      },
      "description": "C# Language Server (csharp-ls) for .NET 10. Install with: dotnet tool install --global csharp-ls"
    }
  }
}
