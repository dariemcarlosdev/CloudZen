@using CloudZen.Models
@using CloudZen.Services.Abstractions
@inject IChatbotService ChatbotService

<div class="chatbot-widget">
    @* Floating toggle button *@
    <button class="chatbot-fab @(isOpen ? "fab-active" : "")" @onclick="ToggleChat" title="Chat with CloudZen AI">
        @if (isOpen)
        {
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M18 6L6 18M6 6l12 12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        }
        else
        {
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        }
    </button>

    @* Chat panel *@
    @if (isOpen)
    {
        <div class="chat-container">
            @* Header *@
            <div class="chat-header">
                <div class="logo-mark"><img src="images/cloudzen-logo.png" alt="CloudZen" /></div>
                <div class="header-text">
                    <h2>CloudZen Assistant</h2>
                    <p>Empowering businesses with smart technology</p>
                </div>
                <div class="online-dot"></div>
            </div>

            @* Messages *@
            <div class="messages-area" @ref="messagesAreaRef">
                @foreach (var msg in messages)
                {
                    <div class="message-row @(msg.Role == "user" ? "user" : "")">
                        <div class="avatar @(msg.Role == "user" ? "user-av" : "bot")">
                            @if (msg.Role == "user")
                            {
                                <span>👤</span>
                            }
                            else
                            {
                                <img src="images/cloudzen-logo.png" alt="CloudZen" />
                            }
                        </div>
                        <div class="bubble @(msg.Role == "user" ? "user" : "bot")">
                            @if (msg.Role == "user")
                            {
                                @msg.Content
                            }
                            else
                            {
                                @((MarkupString)HighlightContactInfo(msg.Content))
                            }
                        </div>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="message-row">
                        <div class="avatar bot"><img src="images/cloudzen-logo.png" alt="CloudZen" /></div>
                        <div class="bubble bot">
                            <div class="typing-indicator">
                                <div class="typing-dot"></div>
                                <div class="typing-dot"></div>
                                <div class="typing-dot"></div>
                            </div>
                        </div>
                    </div>
                }
                <div @ref="messagesEndRef"></div>
            </div>

            @* Suggested questions *@
            @if (showSuggestions)
            {
                <div class="suggestions">
                    @foreach (var question in suggestedQuestions)
                    {
                        <button class="suggestion-chip" @onclick="() => SendMessage(question)">
                            @question
                        </button>
                    }
                </div>
            }

            @* Input area *@
            <div class="input-area">
                @if (UserMessageCount >= MaxUserMessages)
                {
                    <div class="conversation-limit-cta">
                        <p>Thanks for your interest! For personalized answers, let's talk directly.</p>
                        <a href="mailto:cloudzen.inc@gmail.com?subject=Free%20Consultation%20Request" class="cta-button">
                            📧 Book a Free Consultation
                        </a>
                        <p class="cta-subtext">cloudzen.inc@gmail.com · Replies within 24h</p>
                    </div>
                }
                else
                {
                    <div class="input-row">
                        <textarea @bind="inputText"
                                  @bind:event="oninput"
                                  @onkeydown="HandleKeyDown"
                                  placeholder="Ask about CloudZen's services, projects, or process..."
                                  rows="1"
                                  disabled="@isLoading"></textarea>
                        <button class="send-btn" @onclick="() => SendMessage(null)" disabled="@(string.IsNullOrWhiteSpace(inputText) || isLoading)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M22 2L11 13M22 2L15 22L11 13M11 13L2 9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </div>
                    <p class="footer-hint">cloudzen.inc@gmail.com · Replies within 24h · @(MaxUserMessages - UserMessageCount) questions remaining</p>
                }
            </div>
        </div>
    }
</div>

@code {
    private const int MaxUserMessages = 5;

    private List<ChatMessage> messages = new()
    {
        ChatMessage.Assistant("Hi! I'm the CloudZen assistant 👋 I can answer questions about our services, past projects, and how we help small businesses grow with technology. What can I help you with today?")
    };

    private string inputText = string.Empty;
    private bool isLoading;
    private bool isOpen;
    private bool showSuggestions = true;

    private ElementReference messagesAreaRef;
    private ElementReference messagesEndRef;

    private int UserMessageCount => messages.Count(m => m.Role == "user");

    private readonly string[] suggestedQuestions =
    [
        "What does CloudZen do?",
        "Can you help modernize my old system?",
        "How do I get started?",
        "Tell me about your past projects"
    ];

    private void ToggleChat()
    {
        isOpen = !isOpen;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage(null);
        }
    }

    private async Task SendMessage(string? suggestedText)
    {
        var text = suggestedText ?? inputText?.Trim();
        if (string.IsNullOrWhiteSpace(text) || isLoading) return;
        if (UserMessageCount >= MaxUserMessages) return;

        inputText = string.Empty;
        showSuggestions = false;

        messages.Add(ChatMessage.User(text));
        isLoading = true;
        StateHasChanged();

        // Small delay to allow the UI to update and show the typing indicator
        await Task.Delay(50);

        var result = await ChatbotService.SendMessageAsync(messages);

        if (result.Success && !string.IsNullOrEmpty(result.Reply))
        {
            messages.Add(ChatMessage.Assistant(result.Reply));

            // After reaching the limit, add a final CTA message
            if (UserMessageCount >= MaxUserMessages)
            {
                messages.Add(ChatMessage.Assistant(
                    "I hope that was helpful! Every business is unique, so I'd love for you to connect directly with CloudZen for a personalized conversation. You can book a free consultation by emailing cloudzen.inc@gmail.com - replies within 24 hours! 🚀"));
            }
        }
        else
        {
            messages.Add(ChatMessage.Assistant(
                result.Error ?? "Something went wrong. Please email cloudzen.inc@gmail.com directly."));
        }

        isLoading = false;
        StateHasChanged();
    }
}
