@* Injects IJSRuntime to enable JavaScript interop for client-side features (e.g., animations, file downloads) *@
@inject IJSRuntime JS

<section id="value" class="py-24 bg-gray-50 text-center">
    <div class="w-full" style="padding:0;margin:0;">
        <h2 class="text-4xl font-bold mb-4 bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">What You Get</h2>
        <div class="grid md:grid-cols-2 gap-10">
            @* Last significant change: Updated layout so icon spans appear above text for mobile (flex-col) and beside text for desktop (flex-row). *@
            <div class="flex flex-col md:flex-row items-center md:items-start gap-4 group transition duration-300 hover:-translate-y-1 hover:shadow-lg bg-white p-5 rounded-xl border border-gray-100" data-reveal>
                <span class="w-12 h-12 text-blue-600 flex items-center justify-center text-3xl font-semibold group-hover:scale-110 transition-transform mb-2 md:mb-0">
                    <i class="bi bi-person-check-fill"></i>
                </span>
                <div class="text-center md:text-left">
                    <h3 class="text-xl font-semibold mb-1">One Point of Contact</h3>
                    <p class="text-gray-600 text-base">You talk directly to the person doing the work — no phone trees, no waiting, just straight answers when you need them.</p>
                </div>
            </div>
            <div class="flex flex-col md:flex-row items-center md:items-start gap-4 group transition duration-300 hover:-translate-y-1 hover:shadow-lg bg-white p-5 rounded-xl border border-gray-100" data-reveal>
                <span class="w-12 h-12 text-blue-600 flex items-center justify-center text-3xl font-semibold group-hover:scale-110 transition-transform mb-2 md:mb-0">
                    <i class="bi bi-people-fill"></i>
                </span>
                <div class="text-center md:text-left">
                    <h3 class="text-xl font-semibold mb-1">The Right Help, When You Need It</h3>
                    <p class="text-gray-600 text-base">If your project needs specialized skills, I bring in people I trust — so nothing falls through the cracks.</p>
                </div>
            </div>
            <div class="flex flex-col md:flex-row items-center md:items-start gap-4 group transition duration-300 hover:-translate-y-1 hover:shadow-lg bg-white p-5 rounded-xl border border-gray-100" data-reveal>
                <span class="w-12 h-12 text-blue-600 flex items-center justify-center text-3xl font-semibold group-hover:scale-110 transition-transform mb-2 md:mb-0">
                    <i class="bi bi-graph-up-arrow"></i>
                </span>
                <div class="text-center md:text-left">
                    <h3 class="text-xl font-semibold mb-1">Real-World Results</h3>
                    <p class="text-gray-600 text-base">I've helped businesses ditch slow systems, save hours every week, and win more customers with smoother service.</p>
                </div>
            </div>
            <div class="flex flex-col md:flex-row items-center md:items-start gap-4 group transition duration-300 hover:-translate-y-1 hover:shadow-lg bg-white p-5 rounded-xl border border-gray-100" data-reveal>
                <span class="w-12 h-12 text-blue-600 flex items-center justify-center text-3xl font-semibold group-hover:scale-110 transition-transform mb-2 md:mb-0">
                    <i class="bi bi-bullseye"></i>
                </span>
                <div class="text-center md:text-left">
                    <h3 class="text-xl font-semibold mb-1">Solutions That Fit Your Business</h3>
                    <p class="text-gray-600 text-base">No cookie-cutter approaches. I focus on what actually moves the needle for you — less hassle, more impact.</p>
                </div>
            </div>
        </div>
        <div class="mt-12 text-center">
            <a href="#contact" class="inline-block px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-all duration-300 hover:scale-105">
                Let's Talk About Your Business
            </a>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initReveal");
        }
    }
}
