@using CloudZen.Models

@* BookingConfirmation.razor — Step 3 success confirmation. *@<div class="p-12 md:p-16 text-center">
    <div class="relative inline-block mb-8">
        <div class="absolute inset-0 bg-teal-cyan-aqua-200 rounded-full animate-ping opacity-25"></div>
        <div class="relative w-20 h-20 bg-gradient-to-br from-teal-cyan-aqua-300 to-teal-cyan-aqua-500 rounded-full flex items-center justify-center shadow-lg">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
    </div>

    <h3 class="text-3xl font-bold text-gray-800 mb-3">Meeting Scheduled!</h3>
    <p class="text-lg text-gray-600 mb-2">
        Thank you, <strong>@FullName</strong>!
    </p>

    @if (!string.IsNullOrWhiteSpace(BookingId))
    {
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-teal-cyan-aqua-50 border border-teal-cyan-aqua-200 rounded-lg mb-4">
            <i class="bi bi-bookmark-check-fill text-teal-cyan-aqua-600"></i>
            <span class="text-sm text-gray-700">Booking ID: <strong class="text-teal-cyan-aqua-700 font-mono">@BookingId</strong></span>
        </div>
    }

    <p class="text-gray-500 mb-8 max-w-md mx-auto">
        Your 30-minute CloudZen Virtual Meeting is booked for
        <strong>@TimeSlotRange</strong> on
        <strong>@SelectedDate.ToString("dddd, MMMM dd, yyyy")</strong>.
        We'll send a confirmation to <strong>@Email</strong>.
    </p>

    <div class="bg-gray-50 rounded-xl p-6 mb-8 max-w-md mx-auto">
        <h4 class="font-semibold text-gray-800 mb-3">What happens next?</h4>
        <ul class="text-left text-sm text-gray-600 space-y-2">
            <li class="flex items-center gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-teal-cyan-aqua-400 text-white text-xs flex items-center justify-center font-bold">1</span>
                <span>You'll receive a calendar invite &amp; meeting link</span>
            </li>
            <li class="flex items-center gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-teal-cyan-aqua-400 text-white text-xs flex items-center justify-center font-bold">2</span>
                <span>Our team will prepare for your consultation</span>
            </li>
            <li class="flex items-center gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-teal-cyan-aqua-400 text-white text-xs flex items-center justify-center font-bold">3</span>
                <span>Join the meeting &amp; explore AI solutions for your business</span>
            </li>
        </ul>
    </div>

    <button @onclick="OnReset"
            class="inline-flex items-center px-6 py-3 bg-white border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:border-teal-cyan-aqua-300 hover:text-teal-cyan-aqua-500 transition-all duration-200">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Schedule Another Meeting
    </button>
</div>
