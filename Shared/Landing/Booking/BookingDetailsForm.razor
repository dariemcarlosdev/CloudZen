@using System.ComponentModel.DataAnnotations
@using CloudZen.Models

<div class="flex-1 p-6 md:p-10">
    <h4 class="text-lg font-semibold text-gray-800 mb-6">Enter Details</h4>

    <EditForm Model="@FormModel" OnValidSubmit="OnValidSubmit">
        <DataAnnotationsValidator />

        <!-- Full Name -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">
                <i class="bi bi-person mr-2 text-teal-cyan-aqua-600"></i>Full Name
            </label>
            <InputText @bind-Value="FormModel.FullName"
                       placeholder="John Doe"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.FullName)" class="text-teal-cyan-aqua-600 text-xs mt-1" />
        </div>

        <!-- Phone -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">
                <i class="bi bi-telephone mr-2 text-teal-cyan-aqua-600"></i>Phone
            </label>
            <div class="flex items-center gap-2">
                <span class="text-lg">🇺🇸</span>
                <InputText @bind-Value="FormModel.Phone"
                           placeholder="(555) 123-4567"
                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
                           disabled="@IsSubmitting" />
            </div>
            <ValidationMessage For="@(() => FormModel.Phone)" class="text-teal-cyan-aqua-600 text-xs mt-1" />
        </div>

        <!-- Email -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">
                <i class="bi bi-envelope mr-2 text-teal-cyan-aqua-600"></i>Email Address
            </label>
            <InputText @bind-Value="FormModel.Email"
                       type="email"
                       placeholder="john@example.com"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.Email)" class="text-teal-cyan-aqua-600 text-xs mt-1" />
        </div>

        <!-- Business Name -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">
                <i class="bi bi-building mr-2 text-teal-cyan-aqua-600"></i>Business Name
            </label>
            <InputText @bind-Value="FormModel.BusinessName"
                       placeholder="Name as found on Google"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.BusinessName)" class="text-teal-cyan-aqua-600 text-xs mt-1" />
        </div>

        <!-- Reason for Appointment -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">
                <i class="bi bi-chat-left-text mr-2 text-teal-cyan-aqua-600"></i>Reason for Appointment <span class="text-gray-400 font-normal">(optional)</span>
            </label>
            <InputTextArea @bind-Value="FormModel.Reason"
                       placeholder="Briefly describe the reason for your appointment"
                       rows="3"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed resize-none"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.Reason)" class="text-teal-cyan-aqua-600 text-xs mt-1" />
        </div>

        <!-- Opt-In Consent -->
        <div class="mb-6">
            <label class="flex items-start gap-3 cursor-pointer">
                <InputCheckbox @bind-Value="FormModel.OptInConsent"
                               class="mt-1 accent-teal-cyan-aqua-400 w-4 h-4"
                               disabled="@IsSubmitting" />
                <span class="text-sm text-gray-600 leading-snug">
                    I confirm that I want to receive content from this company using any contact information I provide.
                </span>
            </label>
            <ValidationMessage For="@(() => FormModel.OptInConsent)" class="text-teal-cyan-aqua-600 text-xs mt-1" />
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            @if (IsSlotTaken)
            {
                <div role="alert" class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-xl flex items-start gap-3">
                    <div class="flex-shrink-0 w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center">
                        <i class="bi bi-calendar-x text-amber-600"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-amber-800">Time Slot Unavailable</p>
                        <p class="text-sm text-amber-700 mt-1">@ErrorMessage</p>
                        <button type="button"
                                @onclick="OnChooseDifferentTime"
                                class="inline-flex items-center mt-3 px-4 py-2 bg-white border border-amber-300 text-amber-700 text-sm font-semibold rounded-lg hover:bg-amber-50 hover:border-amber-400 focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-amber-300 transition-all duration-200">
                            <i class="bi bi-arrow-left mr-2"></i>
                            Choose a different time
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div role="alert" class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                    <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                        <i class="bi bi-exclamation-triangle text-red-600"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-red-800">Unable to schedule meeting</p>
                        <p class="text-sm text-red-600 mt-1">@ErrorMessage</p>
                        <p class="text-xs text-red-500 mt-2">
                            Please check your details and try again. If the problem persists,
                            <a href="mailto:cloudzen.inc@gmail.com"
                               class="underline font-medium text-red-600 hover:text-red-700 transition-colors">
                                contact us directly</a>.
                        </p>
                    </div>
                </div>
            }
        }

        <!-- Submit -->
        <div class="mt-8">
            <button type="submit"
                    class="w-full group relative px-8 py-4 bg-teal-cyan-aqua-600 text-white font-semibold rounded-full hover:bg-teal-cyan-aqua-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-cyan-aqua-300 disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-300 shadow-lg shadow-gray-300 hover:shadow-xl hover:shadow-gray-400"
                    disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span class="flex items-center justify-center">
                        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Scheduling your meeting...
                    </span>
                }
                else
                {
                    <span class="flex items-center justify-center">
                        <i class="bi bi-calendar-check mr-2 transition-transform group-hover:translate-x-1"></i>
                        Schedule Meeting
                    </span>
                }
            </button>
        </div>
    </EditForm>
</div>
