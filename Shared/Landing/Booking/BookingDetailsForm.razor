@using System.ComponentModel.DataAnnotations
@using CloudZen.Models

<div class="flex-1 p-6 md:p-10">
    <h4 class="text-lg font-semibold text-gray-800 mb-6">Enter Details</h4>

    <EditForm Model="@FormModel" OnValidSubmit="OnValidSubmit">
        <DataAnnotationsValidator />

        <!-- Full Name -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">Full Name <span class="text-red-400">*</span></label>
            <InputText @bind-Value="FormModel.FullName"
                       placeholder="Full Name"
                       class="w-full px-4 py-3 bg-gray-100 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-300 focus:border-transparent transition disabled:opacity-50"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.FullName)" class="text-red-500 text-xs mt-1" />
        </div>

        <!-- Phone -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">Phone <span class="text-red-400">*</span></label>
            <div class="flex items-center gap-2">
                <span class="text-lg">🇺🇸</span>
                <InputText @bind-Value="FormModel.Phone"
                           placeholder="Phone"
                           class="w-full px-4 py-3 bg-gray-100 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-300 focus:border-transparent transition disabled:opacity-50"
                           disabled="@IsSubmitting" />
            </div>
            <ValidationMessage For="@(() => FormModel.Phone)" class="text-red-500 text-xs mt-1" />
        </div>

        <!-- Email -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">Email <span class="text-red-400">*</span></label>
            <InputText @bind-Value="FormModel.Email"
                       type="email"
                       placeholder="Email"
                       class="w-full px-4 py-3 bg-gray-100 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-300 focus:border-transparent transition disabled:opacity-50"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.Email)" class="text-red-500 text-xs mt-1" />
        </div>

        <!-- Business Name -->
        <div class="mb-5">
            <label class="block text-sm font-semibold text-gray-700 mb-1">Business Name <span class="text-red-400">*</span></label>
            <InputText @bind-Value="FormModel.BusinessName"
                       placeholder="Name as Found on Google"
                       class="w-full px-4 py-3 bg-gray-100 border border-gray-200 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-300 focus:border-transparent transition disabled:opacity-50"
                       disabled="@IsSubmitting" />
            <ValidationMessage For="@(() => FormModel.BusinessName)" class="text-red-500 text-xs mt-1" />
        </div>

        <!-- Opt-In Consent -->
        <div class="mb-6">
            <label class="block text-sm font-semibold text-gray-700 mb-1">Opt-In Consent <span class="text-red-400">*</span></label>
            <label class="flex items-start gap-3 cursor-pointer">
                <InputCheckbox @bind-Value="FormModel.OptInConsent"
                               class="mt-1 accent-teal-cyan-aqua-400 w-4 h-4"
                               disabled="@IsSubmitting" />
                <span class="text-sm text-gray-600 leading-snug">
                    I confirm that I want to receive content from this company using any contact information I provide.
                </span>
            </label>
            <ValidationMessage For="@(() => FormModel.OptInConsent)" class="text-red-500 text-xs mt-1" />
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
                @ErrorMessage
            </div>
        }

        <!-- Submit -->
        <div class="flex justify-end">
            <button type="submit"
                    class="px-6 py-3 rounded-lg bg-teal-cyan-aqua-400 text-white font-semibold hover:bg-teal-cyan-aqua-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-cyan-aqua-300 disabled:opacity-50 disabled:cursor-not-allowed transition shadow"
                    disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span class="flex items-center gap-2">
                        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Scheduling...
                    </span>
                }
                else
                {
                    <span>Schedule Virtual Meeting</span>
                }
            </button>
        </div>
    </EditForm>
</div>
