@page "/mission"
@using CloudZen.Models

<PageTitle>About Us — CloudZen | Smart Technology for Growing Businesses</PageTitle>
<HeadContent>
    <meta name="description" content="CloudZen specializes in bringing smart technology to growing businesses. We modernize legacy systems, automate repetitive tasks, and deliver tools that streamline operations." />
    <link rel="canonical" href="https://www.cloud-zen.net/mission" />
</HeadContent>

<section id="mission" class="pt-24 pb-0 bg-white">

    @* ── Section 1: "About Us" hero row ── *@
    <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-3">About Us</h1>
        <div class="w-16 h-1 bg-teal-cyan-aqua-600 mx-auto rounded-full"></div>
    </div>

    @* Row: Text left, Icon right *@
    <div class="flex flex-col md:flex-row items-center gap-10 max-w-6xl mx-auto px-6 mb-24">
        <div class="flex-1 text-center md:text-left">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-4 leading-snug">
                We Specialize in Bringing<br />
                <span class="text-teal-cyan-aqua-600">Smart Technology</span> to Growing Businesses
            </h2>
            <div class="w-16 h-1 bg-teal-cyan-aqua-600 rounded-full mb-4 mx-auto md:mx-0"></div>
            <p class="text-gray-500 leading-relaxed mb-6">
                CloudZen's goal is to help businesses break free from slow, outdated systems and missed opportunities — making day-to-day operations smoother and helping everyone grow.
            </p>
            <a href="#contact" class="inline-block px-8 py-3 bg-orange-400 text-white font-semibold rounded-full hover:bg-orange-500 transition-all duration-300 hover:scale-105">
                GET STARTED →
            </a>
        </div>
        <div class="flex-1 flex items-center justify-center">
            <div class="w-48 h-48 bg-teal-cyan-aqua-50 rounded-full flex items-center justify-center text-teal-cyan-aqua-600">
                <i class="bi bi-briefcase text-7xl" aria-hidden="true"></i>
            </div>
        </div>
    </div>

    @* ── Section 2: "Our Mission" row (reversed) ── *@
    <div class="flex flex-col md:flex-row-reverse items-center gap-10 max-w-6xl mx-auto px-6 mb-24">
        <div class="flex-1 text-center md:text-left">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-4 leading-snug">
                Our mission is to<br />
                <span class="text-teal-cyan-aqua-600">empower businesses</span> to achieve their goals
            </h2>
            <p class="text-gray-500 leading-relaxed mb-6">
                We believe the right tools and automation can improve everyone's work. Whether you are a business owner or the very customer engaging with that business, CloudZen builds solutions to help with:
            </p>
            <ul class="space-y-2 text-left max-w-sm mx-auto md:mx-0">
                @foreach (var point in _missionPoints)
                {
                    <li class="flex items-center gap-2 text-gray-600">
                        <i class="bi bi-check-circle-fill text-teal-cyan-aqua-600"></i>
                        @point
                    </li>
                }
            </ul>
        </div>
        <div class="flex-1 flex items-center justify-center">
            <div class="w-48 h-48 bg-teal-cyan-aqua-50 rounded-full flex items-center justify-center text-teal-cyan-aqua-600">
                <i class="bi bi-rocket-takeoff text-7xl" aria-hidden="true"></i>
            </div>
        </div>
    </div>

    @* ── Section 3: "Our Standards" grid ── *@
    <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-3">Our Standards</h2>
        <div class="w-16 h-1 bg-teal-cyan-aqua-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-y-10 gap-x-8 max-w-5xl mx-auto px-6">
        @foreach (var standard in _standards)
        {
            <StandardCard Standard="@standard" />
        }
    </div>

    @* ── Section 4: "Empower" banner ── *@
    <div class="text-center py-16 mt-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-800 italic mb-2">
            We want to empower your business along the way!
        </h2>
        <p class="text-xl md:text-2xl font-bold text-gray-800">
            Visit our <a href="/contact" class="text-teal-cyan-aqua-600 underline decoration-teal-cyan-aqua-600 underline-offset-4 hover:text-teal-cyan-aqua-400 transition">contact page</a>
        </p>
    </div>

    @* ── Section 5: Dark CTA footer ── *@
    <div class="bg-gray-700 text-white text-center py-16 px-6">
        <h2 class="text-2xl md:text-3xl mb-4">
            Start growing with <span class="font-bold">CloudZen SmartSystems</span> today!
        </h2>
        <div class="w-16 h-1 bg-teal-cyan-aqua-600 mx-auto rounded-full mb-8"></div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="px-8 py-3 bg-orange-400 text-white font-semibold rounded-full hover:bg-orange-500 transition-all duration-300 hover:scale-105 uppercase tracking-wide">
                Get Started →
            </a>
            <a href="/contact" class="px-8 py-3 bg-white text-gray-800 font-semibold rounded-full border border-white hover:bg-gray-100 transition-all duration-300 hover:scale-105 uppercase tracking-wide">
                Request Demo
            </a>
        </div>
    </div>

</section>
