@using CloudZen.Models

@* A single standard card: icon, title, and description. *@

<div class="flex flex-col items-center text-center px-4 py-6">
    <div class="w-16 h-16 mb-4 bg-teal-cyan-aqua-50 rounded-full flex items-center justify-center text-teal-cyan-aqua-600 text-3xl">
        <i class="bi @Standard.IconClass"></i>
    </div>
    <h4 class="text-lg font-bold text-gray-800 mb-2">@Standard.Title</h4>
    <p class="text-gray-500 text-sm leading-relaxed max-w-xs">@Standard.Description</p>
</div>

@code {
    [Parameter, EditorRequired]
    public StandardInfo Standard { get; set; } = default!;
}
