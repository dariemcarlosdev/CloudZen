@using CloudZen.Models
@using CloudZen.Services.Abstractions
@using CloudZen.Shared.Landing.Booking

@* =============================================================================
   BookingContact.razor — Multi-step scheduling & contact orchestrator
   Holds state and composes child components via parameters / EventCallbacks.
   Flow:
     Step 1: Select Date & Time  → BookingSidebar, BookingCalendar, BookingTimeSlots
     Step 2: Enter Details       → BookingSidebar, BookingDetailsForm
     Step 3: Confirmation        → BookingConfirmation
   ============================================================================= *@

<section id="booking" class="py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Header -->
        <div class="text-center mb-10">
            <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-2">Get In Touch</h2>
            <div class="w-16 h-1 bg-teal-cyan-aqua-600 mx-auto mb-4 rounded-full"></div>
            <p class="text-gray-400 text-base">What Can We Help You With Today?</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">

            @* ── STEP 1: Select Date & Time ──────────────────────────────── *@
            @if (currentStep == Step.SelectDateTime)
            {
                <div class="flex flex-col md:flex-row min-h-[520px]">
                    <BookingSidebar SelectedDate="@selectedDate" />

                    <BookingCalendar DisplayMonth="@displayMonth"
                                     SelectedDate="@selectedDate"
                                     TimeZoneLabel="@timeZoneLabel"
                                     OnDateSelected="SelectDate"
                                     OnDisplayMonthChanged="SetDisplayMonth"
                                     OnTimeZoneChanged="HandleTimeZoneChanged" />

                    @if (selectedDate.HasValue)
                    {
                        <BookingTimeSlots TimeSlots="@BookingService.AvailableTimeSlots"
                                          SelectedTime="@selectedTime"
                                          OnTimeSelected="SelectTime"
                                          OnConfirmed="ConfirmDateTime" />
                    }
                </div>
            }

            @* ── STEP 2: Enter Details ───────────────────────────────────── *@
            @if (currentStep == Step.EnterDetails)
            {
                <div class="flex flex-col md:flex-row min-h-[520px]">
                    <BookingSidebar SelectedDate="@selectedDate"
                                    TimeSlotRange="@BookingService.FormatSlotRange(selectedTime)"
                                    TimeZoneLabel="@timeZoneLabel"
                                    ShowBackButton="true"
                                    OnBackClicked="GoBackToCalendar" />

                    <BookingDetailsForm FormModel="@bookingForm"
                                        IsSubmitting="@isSubmitting"
                                        ErrorMessage="@errorMessage"
                                        OnValidSubmit="HandleBookingSubmit" />
                </div>
            }

            @* ── STEP 3: Confirmation ────────────────────────────────────── *@
            @if (currentStep == Step.Confirmation)
            {
                <BookingConfirmation FullName="@(bookingForm.FullName ?? string.Empty)"
                                     Email="@(bookingForm.Email ?? string.Empty)"
                                     TimeSlotRange="@BookingService.FormatSlotRange(selectedTime)"
                                     SelectedDate="@selectedDate!.Value"
                                     OnReset="ResetBooking" />
            }
        </div>
    </div>
</section>
