@using CloudZen.Models
@using CloudZen.Services
@inject ToolService ToolService

@* Section: "All the tools you need to grow in one place."
   Displays a grid of tool cards with SVG icons.
   Includes the "What You Get" value propositions (previously in ValueProposition.razor). *@

<section id="tools" class="py-24 bg-white text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        All the tools you need to grow in one place.
    </h2>
    <div class="w-24 h-1 bg-teal-cyan-aqua-600 mx-auto mb-16 rounded-full"></div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-y-14 gap-x-8 max-w-6xl mx-auto px-6">
        @foreach (var tool in _tools)
        {
            <ToolCardItem Tool="@tool" />
        }
    </div>

    <div class="mt-16 text-center">
        <a href="#contact" class="inline-block px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-all duration-300 hover:scale-105">
            <i class="bi bi-chat-dots mr-2 transition-transform group-hover:translate-x-1"></i>
            Let's Talk About Your Business
        </a>
    </div>
</section>

@code {
    private List<ToolInfo> _tools = new();

    protected override void OnInitialized()
    {
        _tools = ToolService.GetAllTools();
    }
}
