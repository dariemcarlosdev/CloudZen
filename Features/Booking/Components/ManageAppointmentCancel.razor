@using CloudZen.Features.Booking.Models
@using CloudZen.Features.Booking.Services

<div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
    @if (isConfirmed)
    {
        <!-- Success State -->
        <div class="p-12 md:p-16 text-center">
            <div class="relative inline-block mb-8">
                <div class="absolute inset-0 bg-teal-cyan-aqua-200 rounded-full animate-ping opacity-25"></div>
                <div class="relative w-20 h-20 bg-gradient-to-br from-teal-cyan-aqua-300 to-teal-cyan-aqua-500 rounded-full flex items-center justify-center shadow-lg">
                    <i class="bi bi-check-lg text-white text-4xl"></i>
                </div>
            </div>

            <h3 class="text-3xl font-bold text-gray-800 mb-3">Appointment Cancelled</h3>
            <p class="text-gray-500 mb-8 max-w-md mx-auto">
                Your appointment <strong class="text-gray-700 font-mono">@cancelForm.BookingId</strong> has been successfully cancelled.
                A confirmation email has been sent to <strong>@cancelForm.Email</strong>.
            </p>

            <button @onclick="Reset"
                    class="inline-flex items-center px-6 py-3 bg-white border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:border-teal-cyan-aqua-300 hover:text-teal-cyan-aqua-500 transition-all duration-200">
                <i class="bi bi-arrow-repeat mr-2"></i>
                Manage Another Appointment
            </button>
        </div>
    }
    else
    {
        <div class="p-8 md:p-12">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center">
                    <i class="bi bi-x-circle text-red-600 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-gray-800">Cancel Appointment</h3>
                    <p class="text-gray-500 text-sm">Enter your booking details to cancel your appointment</p>
                </div>
            </div>

            <EditForm Model="@cancelForm" OnValidSubmit="HandleCancel">
                <DataAnnotationsValidator />

                <!-- Booking ID -->
                <div class="mb-5">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        <i class="bi bi-bookmark mr-2 text-teal-cyan-aqua-600"></i>Booking ID
                    </label>
                    <InputText @bind-Value="cancelForm.BookingId"
                               placeholder="APT-MN7O3825-TMVP"
                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 font-mono disabled:opacity-50 disabled:cursor-not-allowed"
                               disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => cancelForm.BookingId)" class="text-red-500 text-xs mt-1" />
                    <p class="text-xs text-gray-400 mt-1">You can find this in your confirmation email</p>
                </div>

                <!-- Email -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        <i class="bi bi-envelope mr-2 text-teal-cyan-aqua-600"></i>Email Address
                    </label>
                    <InputText @bind-Value="cancelForm.Email"
                               type="email"
                               placeholder="john@example.com"
                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-cyan-aqua-600 focus:border-transparent transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
                               disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => cancelForm.Email)" class="text-red-500 text-xs mt-1" />
                </div>

                <!-- Error Message -->
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div role="alert" class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3">
                        <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                            <i class="bi bi-exclamation-triangle text-red-600"></i>
                        </div>
                        <div>
                            <p class="font-semibold text-red-800">Unable to cancel appointment</p>
                            <p class="text-sm text-red-600 mt-1">@errorMessage</p>
                        </div>
                    </div>
                }

                <!-- Warning -->
                <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-xl">
                    <div class="flex items-start gap-3">
                        <i class="bi bi-exclamation-triangle text-amber-600 mt-0.5"></i>
                        <div class="text-sm text-amber-800">
                            <p class="font-semibold">This action cannot be undone</p>
                            <p class="mt-1 text-amber-700">Once cancelled, you will need to book a new appointment if you change your mind.</p>
                        </div>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full px-8 py-4 bg-red-600 text-white font-semibold rounded-full hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-300 disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-300 shadow-lg"
                        disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="flex items-center justify-center">
                            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Cancelling appointment...
                        </span>
                    }
                    else
                    {
                        <span class="flex items-center justify-center">
                            <i class="bi bi-x-circle mr-2"></i>
                            Cancel Appointment
                        </span>
                    }
                </button>
            </EditForm>
        </div>
    }
</div>

@code {
    [Inject] private IAppointmentService AppointmentService { get; set; } = default!;

    private CancelFormModel cancelForm = new();
    private bool isSubmitting;
    private bool isConfirmed;
    private string? errorMessage;

    private async Task HandleCancel()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var request = new CancelAppointmentRequest
            {
                BookingId = cancelForm.BookingId!,
                Email = cancelForm.Email!
            };

            var result = await AppointmentService.CancelAsync(request);

            if (result.Success)
            {
                isConfirmed = true;
            }
            else
            {
                errorMessage = result.Error ?? "We couldn't cancel your appointment. Please try again.";
            }
        }
        catch
        {
            errorMessage = "Something went wrong. Please try again later.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Reset()
    {
        cancelForm = new CancelFormModel();
        isConfirmed = false;
        errorMessage = null;
    }
}
