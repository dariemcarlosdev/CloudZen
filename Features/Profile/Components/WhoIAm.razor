@page "/whoiam"

<PageTitle>Who I Am — Dariem C. Macias | CloudZen Software Engineer & Consultant</PageTitle>
<HeadContent>
    <meta name="description" content="Meet Dariem C. Macias — Software Engineer and Consultant at CloudZen. Over seven years helping businesses replace outdated systems with modern, reliable solutions using AI and automation." />
    <link rel="canonical" href="https://www.cloud-zen.net/whoiam" />
</HeadContent>

<!-- Last significant change: Refactored to use ProfileHeader and ProfileApproach components. Projects loaded from ProjectService. -->
<section id="who-i-am" class="bg-white pt-8 pb-0">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <ProfileHeader 
            AvatarUrl="/images/dariem-avatar.png"
            AltText="Dariem C. Macias - CloudZen"
            Title="Who I Am"
            NameHighlight="Dariem C. Macias here"
            RoleDescription="Software Engineer and Consultant - I build the systems that help businesses run smoother, move faster, and stress less about tech."
            DetailedDescription="For over seven years, I've helped businesses replace slow, outdated systems with modern solutions that actually work. I build software that runs reliably, scales as you grow, and makes day-to-day operations smoother. Lately, I've been helping teams use AI and automation to save time on repetitive tasks and make smarter decisions - without the complexity."
            LinkedInUrl="https://www.linkedin.com/in/dariemcmacias"
            GitHubUrl="https://github.com/dariemcarlosdev?tab=repositories" />
    </div>

    <!-- SDLC Process Panel -->
    <SDLCProcess />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start mt-12 md:mt-16">
            <!-- Left Column: Bio -->
            <ProfileApproach />
            <!-- Right Column: Results Highlights -->
            <ProfileHighlights OnResumeDownload="DownloadResume" />
        </div>

        <!-- Projects Section -->
        <div class="mt-16 md:mt-20">
            <div class="text-center mb-10">
                <h2 id="highlighted-projects" class="text-3xl font-bold text-gray-800 mb-3">Highlighted Projects</h2>
                <div class="w-16 h-1 bg-teal-cyan-aqua-600 mx-auto rounded-full mb-4"></div>
                <p class="text-gray-500 max-w-2xl mx-auto">
                    Real-world projects showcasing software engineering, cloud-native design, and applied AI — built from scratch, iterated fast, and delivered production-ready.
                </p>
            </div>

            <!-- Project Filter Component -->
            <ProjectFilter OnFilterChange="HandleFilterChange" />

            <!-- Projects List -->
            @if (FilteredProjects.Any())
            {
                <div class="flex flex-col gap-6 md:gap-8">
                    @foreach (var project in FilteredProjects)
                    {
                        <ProjectCard Project="@project" />
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12">
                    <i class="bi bi-inbox text-6xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500 text-lg">No projects match the selected filters.</p>
                    <p class="text-gray-400 text-sm mt-2">Try adjusting or clearing your filters.</p>
                </div>
            }
        </div>
    </div>

    <!-- Bottom CTA -->
    <div class="bg-gray-700 text-white text-center py-12 md:py-16 mt-16">
        <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <h2 class="text-2xl md:text-3xl font-bold mb-4">Like what you see?</h2>
            <p class="text-gray-300 mb-8">Let's talk about how I can help your business grow.</p>
            <a href="/contact" class="inline-block px-8 py-3 bg-orange-400 text-white font-semibold rounded-full hover:bg-orange-500 transition-all duration-300 hover:scale-105 uppercase tracking-wide">
                Get In Touch →
            </a>
        </div>
    </div>
</section>

