
@* A single tool card: icon, title, and description. Reusable via the Tool parameter. *@

<div class="flex flex-col items-center text-center px-4 py-6">
    <div class="mb-4 text-teal-cyan-aqua-500 text-6xl">
        @((MarkupString)Tool.IconMarkup)
    </div>
    <h3 class="text-xl font-bold text-gray-800 mb-2">@Tool.Title</h3>
    <p class="text-gray-500 text-sm leading-relaxed max-w-xs">@Tool.Description</p>
</div>

@code {
    [Parameter, EditorRequired]
    public ToolInfo Tool { get; set; } = default!;
}
