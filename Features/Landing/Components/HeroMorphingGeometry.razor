@namespace CloudZen.Features.Landing.Components

<!--
    HeroMorphingGeometry Component
    Light-themed hero section with:
    - Morphing blob/circle geometric shapes
    - Soft gradient background
    - Badge/pill indicator
    - Bold headline with accent colors
    - Two CTA buttons
    - Stats metrics row
    
    Usage:
        <HeroMorphingGeometry />
-->

<section id="hero-morph" class="hero-morphing">
    <!-- Morphing geometric blobs -->
    <div class="blobs-container" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="blob blob-4"></div>
        <div class="blob blob-5"></div>
    </div>

    <!-- Floating circles -->
    <div class="circles-container" aria-hidden="true">
        <div class="morph-circle circle-1"></div>
        <div class="morph-circle circle-2"></div>
        <div class="morph-circle circle-3"></div>
    </div>

    <!-- Gradient overlay -->
    <div class="gradient-overlay" aria-hidden="true"></div>

    <div class="hero-content">
        <!-- Badge -->
        <div class="hero-badge">
            <span class="badge-dot"></span>
            <span class="badge-text">BUILD &amp; GROW MODEL</span>
        </div>

        <!-- Headline -->
        <h1 class="hero-headline">
            <span class="headline-line">Technology that</span>
            <span class="headline-line">works the way</span>
            <span class="headline-line text-accent">you do.</span>
        </h1>

        <!-- Subtext -->
        <p class="hero-subtext">
            Stop trying to fit your business into a box. We build custom tools 
            designed around your daily routine and goals, so technology finally 
            supports you.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-cta">
            <a href="/contact" class="btn-primary">
                Book Free Consultation
            </a>
            <a href="/services" class="btn-outline">
                Explore Services &rarr;
            </a>
        </div>

        <!-- Stats Row -->
        <div class="hero-stats">
            <div class="stat-item">
                <div class="stat-value">
                    <span class="stat-number">1</span>
                    <span class="stat-unit stat-unit--orange">Fee</span>
                </div>
                <div class="stat-label">Flat Build Price</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-value">
                    <span class="stat-number stat-number--teal">100%</span>
                </div>
                <div class="stat-label">Custom to You</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-value">
                    <span class="stat-number">Day</span>
                    <span class="stat-unit">1</span>
                </div>
                <div class="stat-label">Zero-Stress Launch</div>
            </div>
        </div>
    </div>
</section>
