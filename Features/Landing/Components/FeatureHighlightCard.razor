
@* A single feature highlight row: text on one side, illustration on the other.
   The layout alternates direction based on the IsReversed parameter. *@

<div class="flex flex-col @(IsReversed ? "md:flex-row-reverse" : "md:flex-row") items-center gap-6 md:gap-10 py-10 md:py-16 max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Text side -->
    <div class="flex-1 text-center md:text-left">
        @if (!string.IsNullOrEmpty(Feature.Subtitle))
        {
            <p class="text-sm font-semibold text-gray-500 mb-1">@Feature.Subtitle</p>
        }
        <h3 class="text-2xl md:text-3xl font-bold text-gray-800 mb-3 leading-snug">
            @Feature.TitlePrefix<span class="text-teal-cyan-aqua-600 italic">@Feature.TitleBold</span>@Feature.TitleSuffix
        </h3>
        <div class="w-16 h-1 bg-teal-cyan-aqua-600 rounded-full mb-4 mx-auto md:mx-0"></div>
        <p class="text-gray-500 leading-relaxed">@Feature.Description</p>
    </div>
    <!-- Image side -->
    <div class="flex-1 flex items-center justify-center">
        <img src="@Feature.ImagePath" alt="@Feature.TitleBold @Feature.TitleSuffix" class="w-full max-w-sm object-contain" loading="lazy" width="384" height="256" />
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public FeatureHighlight Feature { get; set; } = default!;

    /// <summary>
    /// When true, the image appears on the left and text on the right.
    /// </summary>
    [Parameter]
    public bool IsReversed { get; set; }
}
