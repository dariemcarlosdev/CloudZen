<header class="fixed top-0 left-0 z-50 w-full h-16 bg-white/95 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto h-full flex justify-between items-center px-4 sm:px-6">

        @* ── Logo ── *@
        <a href="" class="flex items-center font-ibm-plex text-gray-800 hover:text-teal-cyan-aqua-600 transition-colors">
            <img src="/images/HeaderLogo.png" alt="CloudZen Logo"
                 class="h-10 object-contain" width="120" height="40" />
        </a>

        @* ── Hamburger (mobile) ── *@
        <button class="md:hidden p-2 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-cyan-aqua-400 @(_isMobileMenuOpen ? "hamburger-open" : "")"
                @onclick="ToggleMobileMenu"
                aria-label="@(_isMobileMenuOpen ? "Close menu" : "Open menu")"
                aria-expanded="@_isMobileMenuOpen.ToString().ToLowerInvariant()">
            <span class="flex flex-col justify-center items-center gap-[5px]">
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
                <span class="hamburger-bar"></span>
            </span>
        </button>

        @* ── Desktop nav ── *@
        <nav class="hidden md:flex items-center gap-7 text-sm" aria-label="Main navigation">
            <NavLink href="/services" class="nav-link text-gray-600 font-medium tracking-wide hover:text-teal-cyan-aqua-600 transition-colors" ActiveClass="nav-link--active">Services</NavLink>
            <a href="/#cases" @onclick='() => SetActive("#cases")' class="nav-link @GetNavClass("#cases") font-medium tracking-wide transition-colors">Our Work</a>
            <NavLink href="/mission" class="nav-link text-gray-600 font-medium tracking-wide hover:text-teal-cyan-aqua-600 transition-colors" ActiveClass="nav-link--active">About</NavLink>
            <NavLink href="/whoiam" class="nav-link text-gray-600 font-medium tracking-wide hover:text-teal-cyan-aqua-600 transition-colors" ActiveClass="nav-link--active">Who I Am</NavLink>
            <NavLink href="/contact" class="cta-button px-5 py-2 bg-orange-400 text-white text-sm font-semibold rounded-full hover:bg-orange-500" ActiveClass="ring-2 ring-orange-300 ring-offset-1">Let's Talk</NavLink>
        </nav>

        @* ── Mobile nav ── *@
        @if (_isMobileMenuOpen)
        {
            <nav class="mobile-nav absolute top-full left-0 w-full bg-white/98 backdrop-blur-md flex flex-col items-center gap-5 py-8 md:hidden shadow-lg border-t border-gray-100 z-50"
                 aria-label="Mobile navigation">
                <NavLink href="/services" class="nav-link text-gray-600 font-medium tracking-wide hover:text-teal-cyan-aqua-600 transition-colors" ActiveClass="nav-link--active" @onclick="CloseMobileMenu">Services</NavLink>
                <a href="/#cases" @onclick='() => OnMobileNavClick("#cases")' class="nav-link @GetNavClass("#cases") font-medium tracking-wide transition-colors">Our Work</a>
                <NavLink href="/mission" class="nav-link text-gray-600 font-medium tracking-wide hover:text-teal-cyan-aqua-600 transition-colors" ActiveClass="nav-link--active" @onclick="CloseMobileMenu">About</NavLink>
                <NavLink href="/whoiam" class="nav-link text-gray-600 font-medium tracking-wide hover:text-teal-cyan-aqua-600 transition-colors" ActiveClass="nav-link--active" @onclick="CloseMobileMenu">Who I Am</NavLink>
                <NavLink href="/contact" class="cta-button px-5 py-2 bg-orange-400 text-white text-sm font-semibold rounded-full hover:bg-orange-500" ActiveClass="ring-2 ring-orange-300 ring-offset-1" @onclick="CloseMobileMenu">Let's Talk</NavLink>
            </nav>
        }
    </div>
</header>

@if (_isMobileMenuOpen)
{
    <div class="mobile-overlay" @onclick="CloseMobileMenu"></div>
}
